# Server
PORT=3001
# Comma-separated; localhost and 127.0.0.1 are different origins for the browser
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- First-time on-chain "Create My Agent" (POST /api/setup) ---
# RPC (Infura, Alchemy, etc.)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Funded Sepolia wallet: pays gas for IdentityRegistry + AgentRegistry txs.
# After register(), this wallet OWNS the ERC-8004 NFT and submits setAgentWallet.
BACKEND_PRIVATE_KEY=0x...

# Optional: operator key that signs EIP-712 for setAgentWallet (defaults to BACKEND_PRIVATE_KEY).
# Must match EncryptedVault.agentOperator if that address should execute deposits.
# OPERATOR_PRIVATE_KEY=0x...

# IPFS: pin agent JSON before IdentityRegistry.register(agentURI)
# Lighthouse is tried first when set. If it fails (e.g. trial expired), Pinata is used when PINATA_JWT is set.
LIGHTHOUSE_API_KEY=
PINATA_JWT=

# Optional: override vault address (defaults to contracts.json → encryptedVault)
# VAULT_CONTRACT_ADDRESS=0x939F26Cd46B4A039C512EBE949F8C10D6545227e
# ── Flow Automation (optional — enables scheduled on-chain deposits) ─────────
# Flow testnet REST access node
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org

# App's Flow account — must hold FLOW tokens to pay scheduling fees
FLOW_ACCOUNT_ADDRESS=0x...
FLOW_PRIVATE_KEY=<hex ECDSA_P256 private key>
FLOW_KEY_INDEX=0

# Deployed AgentScheduler contract address on Flow testnet
AGENT_SCHEDULER_ADDRESS=0x...

# Optional: seconds until first scheduled run (overrides daily/weekly/monthly). Use e.g. 120 for quick tests.
# FLOW_SCHEDULE_DELAY_SECONDS=120

# Demo dashboard (Demo 1m): on by default. Set to false to disable demo HTTP routes (e.g. public deployment):
# NAPFI_DEMO_ENDPOINTS=false
# USDC amount used when API re-loads a registered agent from chain (goal not stored on-chain):
# DEMO_DEFAULT_GOAL_USDC=1

# How the server puts “pending USDC deposit” in the queue for the dashboard to sign:
#   time  (default) — when wall clock passes nextExecutionISO (Flow Cadence can still run; no DepositTriggered needed)
#   chain — only Flow DepositTriggered enqueues (legacy)
# NAPFI_DEPOSIT_QUEUE_SOURCE=chain
#
# Poll interval for the time-based enqueuer (ms):
# NAPFI_SCHEDULE_TIME_POLL_MS=5000
#
# Optional: Bearer secret for POST /api/cron/enqueue-schedule-deposits (same pass as the timer).
# npm run trigger-due-deposits
# NAPFI_CRON_SECRET=generate-a-long-random-string

# ERC-8004 agent ID (set automatically after first setup, or paste manually)
AGENT_ID=

